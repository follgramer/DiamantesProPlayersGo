<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Base application theme for dark mode -->
    <style name="Base.Theme.DiamantesProPlayersGo" parent="Theme.Material3.DayNight">
        <!-- Dark theme colors -->
        <item name="colorPrimary">@color/purple_accent</item>
        <item name="colorPrimaryVariant">@color/primary_dark</item>
        <item name="colorOnPrimary">@color/white</item>

        <item name="colorSecondary">@color/gold_accent</item>
        <item name="colorSecondaryVariant">@color/secondary_dark</item>
        <item name="colorOnSecondary">@color/black</item>

        <item name="colorAccent">@color/accent_color</item>

        <item name="android:colorBackground">@color/black</item>
        <item name="colorOnBackground">@color/white</item>

        <item name="colorSurface">#1E1E1E</item>
        <item name="colorOnSurface">@color/white</item>

        <item name="android:statusBarColor">@color/black</item>
        <item name="android:navigationBarColor">@color/black</item>

        <!-- Custom attributes for dark mode -->
        <item name="android:windowBackground">@color/black</item>
        <item name="android:textColorPrimary">@color/white</item>
        <item name="android:textColorSecondary">#CCCCCC</item>
    </style>

    <!-- Main application theme for dark mode -->
    <style name="Theme.DiamantesProPlayersGo" parent="Base.Theme.DiamantesProPlayersGo">
        <!-- Dark mode specific customizations -->
        <item name="android:windowSplashScreenBackground" tools:targetApi="s">@color/black</item>
        <item name="android:windowSplashScreenAnimatedIcon" tools:targetApi="s">@drawable/ic_trophy</item>
    </style>

</resources>